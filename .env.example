# FrameFlow — API ключи (скопируйте в .env)
# Запуск: дважды кликните FrameFlow.bat

# Провайдер по умолчанию: aitunnel | custom
FRAMEFLOW_PROVIDER=aitunnel

# --- AITunnel (рекомендуется) ---
# Ключ: https://aitunnel.ru
AITUNNEL_API_KEY=

# --- Свой OpenAI-совместимый API ---
# CUSTOM_API_KEY=
# CUSTOM_BASE_URL=https://api.example.com/v1
# CUSTOM_MODELS_URL=https://api.example.com/v1/models
